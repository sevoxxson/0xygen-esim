#!/bin/sh
# hyfetrial - claim a HYFE eSIM Trial number from prioritas.xl.co.id
#
# This is a CLI front-end that automates the same flow as the web app at
#   https://prioritas.xl.co.id/hyfe-apply/esim-trial
#
# License: see repository LICENSE / README.

set -eu

LIB_DIR="${HYFE_LIB_DIR:-/usr/lib/hyfetrial}"
if [ ! -d "$LIB_DIR" ] || [ ! -f "$LIB_DIR/common.sh" ]; then
    # Allow running from a source checkout without installation.
    unset CDPATH
    here=$(cd -- "$(dirname -- "$0")" && pwd)
    for candidate in \
        "$here/lib" \
        "$here/../lib/hyfetrial" \
        "$here/../usr/lib/hyfetrial" \
        "$here/../share/hyfetrial/lib"
    do
        if [ -f "$candidate/common.sh" ]; then
            LIB_DIR=$(cd -- "$candidate" && pwd)
            break
        fi
    done
fi
if [ ! -f "$LIB_DIR/common.sh" ]; then
    printf 'hyfetrial: cannot locate library scripts (LIB_DIR=%s)\n' "$LIB_DIR" >&2
    exit 1
fi

# shellcheck source=src/lib/common.sh
. "$LIB_DIR/common.sh"
# shellcheck source=src/lib/config.sh
. "$LIB_DIR/config.sh"
# shellcheck source=src/lib/api.sh
. "$LIB_DIR/api.sh"
# shellcheck source=src/lib/captcha.sh
. "$LIB_DIR/captcha.sh"
# shellcheck source=src/lib/otp.sh
. "$LIB_DIR/otp.sh"

VERSION="0.1.0"

usage() {
    cat <<EOF
hyfetrial $VERSION - claim a HYFE eSIM Trial number

USAGE:
    hyfetrial                       (mode interaktif - tanya satu per satu)
    hyfetrial -i                    (paksa mode interaktif)
    hyfetrial [OPTIONS]             (mode non-interaktif via flag)
    hyfetrial --list-numbers [--pattern PAT]

CONFIG MANAGEMENT:
    hyfetrial --config              Lihat config aktif (password ter-mask)
    hyfetrial --config FILE         Pakai FILE sebagai config
    hyfetrial --new-config          Wizard setup config dari nol / partial edit
    hyfetrial --captcha-config      Wizard khusus mode + API key captcha
    hyfetrial --imap-config         Wizard khusus setting IMAP
    hyfetrial --email-config        Wizard tambah/hapus akun email + App Password

Tanpa --config FILE, hyfetrial otomatis source /etc/hyfetrial/config kalau
ada. Kalau dijalankan tanpa flag wajib (--name/--whatsapp/--email/--eid),
hyfetrial otomatis masuk mode interaktif dan menanyakan setiap input.

REQUIRED OPTIONS (untuk full claim flow / non-interaktif):
    --name NAME            Full name (e.g. "Andi Pratama")
    --whatsapp NUMBER      WhatsApp number without +62 / leading 0
                           (e.g. 81234567890)
    --email EMAIL          Email address (will receive the OTP)
    --eid EID              eSIM EID, 32 digits
                           (Settings -> About -> EID on most phones)

OPTIONAL:
    --pattern PAT          Filter MSISDN by digit pattern (e.g. 8888)
    --pick-msisdn MSISDN   Select a specific MSISDN from the listing
                           (must appear in --list-numbers output)
    --list-numbers         List candidate MSISDNs and exit
    --pages N              How many pages to scan when listing (default 1)

CAPTCHA:
    --captcha-mode MODE    manual | 2captcha | anticaptcha | capsolver | nextcaptcha
                           (default: manual; manual prompts you to paste a
                            grecaptcha token from a real browser)
    --captcha-key KEY      API key for paid solvers
    --captcha-timeout SEC  Solver timeout (default 180)

OTP:
    --otp-mode MODE        manual | imap (default: manual)
    --imap-url URL         e.g. imaps://imap.gmail.com:993
    --imap-user USER
    --imap-pass PASS
    --imap-folder FOLDER   default: INBOX
    --imap-subject SUBJ    default: "Kode OTP | eSIM Trial HYFE"
    --imap-timeout SEC     default: 180

MISC:
    --config [FILE]        With FILE: source FILE before parsing other
                           options. Without FILE: print active config
                           with passwords masked. CLI flags always
                           override values set in FILE.
    --show-config          Alias for --config without an argument.
    --new-config           Run setup wizard for the active config file.
                           Existing values shown as defaults; press Enter
                           to keep them. Creates /etc/hyfetrial/config
                           if it does not exist.
    --captcha-config       Wizard khusus update mode + API key captcha.
    --imap-config          Wizard khusus update setting IMAP.
    --email-config         Wizard tambah/hapus akun email + App Password
                           (HYFE_EMAIL_N + HYFE_IMAP_PASS_N).
    -i, --interactive      Force interactive prompts even when flags are
                           given (akan menanyakan input yang masih kosong).
    --user-agent STRING    Override User-Agent
    --dry-run              Print payload but do not call validateAndSubmit
    --yes                  Skip the final confirmation prompt
    -v, --verbose          Verbose logging
    -d, --debug            Debug logging (includes HTTP bodies)
    -h, --help             Show this help
        --version          Show version

ENVIRONMENT:
    HYFE_BASE              Override API base URL
    HYFE_AUTH_URL          Override Next.js auth URL
    HYFE_CAPTCHA_MODE      Same as --captcha-mode
    HYFE_CAPTCHA_KEY       Same as --captcha-key
    HYFE_OTP_MODE          Same as --otp-mode
    HYFE_IMAP_URL/USER/PASS/FOLDER/SUBJECT  IMAP settings
    HYFE_VERBOSE / HYFE_DEBUG  Logging

EXAMPLES:
    hyfetrial --list-numbers --pattern 8888
    hyfetrial --name "Andi P" --whatsapp 81234567890 \\
              --email me@example.com \\
              --eid 12345678901234567890123456789012 \\
              --pattern 8888

EOF
}

# ---------- argument parsing ----------

NAME=""
WHATSAPP=""
EMAIL=""
EID=""
PATTERN=""
PICK_MSISDN=""
LIST_ONLY=0
PAGES=1
DRY_RUN=0
ASSUME_YES=0
INTERACTIVE=0
CONFIG_FILE=""
SHOW_CONFIG=0
WIZARD_MODE=""

# Pre-scan args for --config so we can source the config BEFORE the main parse
# loop. That way subsequent CLI flags reliably override config-file values
# (which is the documented "CLI wins" precedence).
#
# `--config` is dual-purpose:
#   --config FILE   -> use FILE as config path
#   --config        -> (no path) print current config (with passwords masked)
# We disambiguate by peeking at the next argument: if it's missing or starts
# with `-`, treat it as no-path "show" mode.
#
# `for _arg do` (without `in ...`) iterates over the positional parameters
# directly, preserving values containing whitespace. Using `for _arg in $*`
# would re-split on $IFS and fragment paths like `--config "/etc/has space".
_pending_cfg=0
for _arg do
    if [ "$_pending_cfg" = 1 ]; then
        case "$_arg" in
            -*)
                # next arg is another flag -> --config was the no-arg form
                SHOW_CONFIG=1
                ;;
            *)
                CONFIG_FILE="$_arg"
                ;;
        esac
        _pending_cfg=0
        continue
    fi
    case "$_arg" in
        --config)         _pending_cfg=1 ;;
        --show-config)    SHOW_CONFIG=1 ;;
        --new-config)     WIZARD_MODE="new" ;;
        --captcha-config) WIZARD_MODE="captcha" ;;
        --imap-config)    WIZARD_MODE="imap" ;;
        --email-config)   WIZARD_MODE="email" ;;
    esac
done
# `--config` was the very last arg with nothing after it.
if [ "$_pending_cfg" = 1 ]; then
    SHOW_CONFIG=1
fi
unset _pending_cfg _arg

# Auto-discover default config if --config was not given explicitly. This
# is the same behaviour as `hyfetrial --config /etc/hyfetrial/config` when
# that file exists, so users don't have to pass --config every time.
if [ -z "$CONFIG_FILE" ] && [ -r "$(config_default_path)" ]; then
    CONFIG_FILE=$(config_default_path)
fi

if [ -n "$CONFIG_FILE" ]; then
    [ -r "$CONFIG_FILE" ] || { printf 'hyfetrial: config not readable: %s\n' "$CONFIG_FILE" >&2; exit 2; }
    # Source the config in a way that does NOT silently kill the whole CLI
    # under `set -eu` if the user's config file has syntax issues. Common
    # mistakes are an unquoted password containing spaces (e.g.
    # `HYFE_IMAP_PASS=abc def ghi`) or a stray space after `=` (e.g.
    # `HYFE_CAPTCHA_KEY= next_xxxx`); both are read by the shell as
    # `VAR=val command args` and fail with `command not found`, which under
    # `set -e` aborts the whole script before we have a chance to print
    # anything useful. Disabling -e for the duration of the source lets us
    # capture the failure and surface a clear, actionable error.
    set +e
    # shellcheck disable=SC1090
    . "$CONFIG_FILE" 2>/tmp/hyfetrial-cfg-err.$$
    _cfg_rc=$?
    set -e
    # We surface ANY stderr output from sourcing (even when the final exit
    # code is 0). The reason: a typo on a middle line - e.g. an unquoted
    # space-containing password - is parsed as `VAR=val command args` and
    # makes the shell try to run `command`, which then prints `not found`
    # to stderr and continues. The final source rc reflects only the LAST
    # statement, so we can't rely on it; instead we trust the stderr file.
    if [ "$_cfg_rc" -ne 0 ] || [ -s /tmp/hyfetrial-cfg-err.$$ ]; then
        if [ "$_cfg_rc" -ne 0 ]; then
            printf 'hyfetrial: failed to source config %s (exit=%d)\n' "$CONFIG_FILE" "$_cfg_rc" >&2
        else
            printf 'hyfetrial: config %s sourced with errors:\n' "$CONFIG_FILE" >&2
        fi
        if [ -s /tmp/hyfetrial-cfg-err.$$ ]; then
            printf 'hyfetrial: shell errors:\n' >&2
            sed 's/^/  /' /tmp/hyfetrial-cfg-err.$$ >&2
        fi
        printf 'hyfetrial: hint: pastikan setiap nilai dengan spasi di-quote, mis.\n' >&2
        printf '  HYFE_IMAP_PASS="abcd efgh ijkl mnop"\n' >&2
        printf '  HYFE_CAPTCHA_KEY=next_77fexxxxxxxx       # tanpa spasi setelah =\n' >&2
        rm -f /tmp/hyfetrial-cfg-err.$$
        exit 2
    fi
    rm -f /tmp/hyfetrial-cfg-err.$$
    unset _cfg_rc
fi

# Parse args (POSIX manual loop)
while [ $# -gt 0 ]; do
    case "$1" in
        --name)             NAME="$2"; shift 2 ;;
        --whatsapp)         WHATSAPP="$2"; shift 2 ;;
        --email)            EMAIL="$2"; shift 2 ;;
        --eid)              EID="$2"; shift 2 ;;
        --pattern)          PATTERN="$2"; shift 2 ;;
        --pick-msisdn)      PICK_MSISDN="$2"; shift 2 ;;
        --list-numbers)     LIST_ONLY=1; shift ;;
        --pages)            PAGES="$2"; shift 2 ;;
        --captcha-mode)     HYFE_CAPTCHA_MODE="$2"; shift 2 ;;
        --captcha-key)      HYFE_CAPTCHA_KEY="$2"; shift 2 ;;
        --captcha-timeout)  HYFE_CAPTCHA_TIMEOUT="$2"; shift 2 ;;
        --otp-mode)         HYFE_OTP_MODE="$2"; shift 2 ;;
        --imap-url)         HYFE_IMAP_URL="$2"; shift 2 ;;
        --imap-user)        HYFE_IMAP_USER="$2"; shift 2 ;;
        --imap-pass)        HYFE_IMAP_PASS="$2"; shift 2 ;;
        --imap-folder)      HYFE_IMAP_FOLDER="$2"; shift 2 ;;
        --imap-subject)     HYFE_IMAP_SUBJECT="$2"; shift 2 ;;
        --imap-timeout)     HYFE_IMAP_TIMEOUT="$2"; shift 2 ;;
        --user-agent)       HYFE_UA="$2"; shift 2 ;;
        --config)
            # --config FILE or --config (no arg, see pre-scan).
            if [ $# -ge 2 ] && [ "${2#-}" = "$2" ]; then
                CONFIG_FILE="$2"; shift 2
            else
                SHOW_CONFIG=1; shift
            fi
            ;;
        --show-config)      SHOW_CONFIG=1; shift ;;
        --new-config)       WIZARD_MODE="new"; shift ;;
        --captcha-config)   WIZARD_MODE="captcha"; shift ;;
        --imap-config)      WIZARD_MODE="imap"; shift ;;
        --email-config)     WIZARD_MODE="email"; shift ;;
        -i|--interactive)   INTERACTIVE=1; shift ;;
        --dry-run)          DRY_RUN=1; shift ;;
        --yes|-y)           ASSUME_YES=1; shift ;;
        -v|--verbose)       HYFE_VERBOSE=1; shift ;;
        -d|--debug)         HYFE_DEBUG=1; shift ;;
        -h|--help)          usage; exit 0 ;;
        --version)          echo "hyfetrial $VERSION"; exit 0 ;;
        --)                 shift; break ;;
        -*)
            printf 'hyfetrial: unknown option: %s\n' "$1" >&2
            exit 2
            ;;
        *)
            printf 'hyfetrial: unexpected positional arg: %s\n' "$1" >&2
            exit 2
            ;;
    esac
done

export HYFE_VERBOSE HYFE_DEBUG \
    HYFE_CAPTCHA_MODE HYFE_CAPTCHA_KEY HYFE_CAPTCHA_TIMEOUT \
    HYFE_OTP_MODE HYFE_IMAP_URL HYFE_IMAP_USER HYFE_IMAP_PASS \
    HYFE_IMAP_FOLDER HYFE_IMAP_SUBJECT HYFE_IMAP_TIMEOUT \
    HYFE_UA HYFE_BASE HYFE_AUTH_URL

# Cookie jar setup is deferred until after the subcommand dispatch at the
# bottom of the file: config-management subcommands don't need curl, jq,
# or a cookie jar.

# ---------- input validation ----------

validate_inputs() {
    err=0
    if [ -z "$NAME" ];     then log_error "missing --name";     err=1; fi
    if [ -z "$WHATSAPP" ]; then log_error "missing --whatsapp"; err=1; fi
    if [ -z "$EMAIL" ];    then log_error "missing --email";    err=1; fi
    if [ -z "$EID" ];      then log_error "missing --eid";      err=1; fi
    [ "$err" = 0 ] || return 1

    # Whatsapp: digits only, no leading 0/+62
    case "$WHATSAPP" in
        +62*) WHATSAPP=${WHATSAPP#+62} ;;
        62*)  WHATSAPP=${WHATSAPP#62} ;;
        0*)   WHATSAPP=${WHATSAPP#0} ;;
    esac
    if ! printf '%s' "$WHATSAPP" | grep -Eq '^[0-9]{8,12}$'; then
        die "invalid --whatsapp: $WHATSAPP (expected 8-12 digits, no +62/0 prefix)"
    fi

    # Email: minimal sanity
    case "$EMAIL" in
        *@*.*) ;;
        *) die "invalid --email: $EMAIL" ;;
    esac

    # EID: 32 digits, allow user to paste with separators
    eid_clean=$(printf '%s' "$EID" | tr -d ' :-')
    if ! printf '%s' "$eid_clean" | grep -Eq '^[0-9]{32}$'; then
        die "invalid --eid: expected 32 digits, got '$EID'"
    fi
    EID="$eid_clean"

    # Pattern: digits only, up to 5
    if [ -n "$PATTERN" ] && ! printf '%s' "$PATTERN" | grep -Eq '^[0-9]{1,5}$'; then
        die "invalid --pattern: $PATTERN (1-5 digits)"
    fi
}

# Pick a random page (mirrors the web app's "Math.floor(496*random)+5" trick
# which spreads requests across the inventory).
random_page() {
    if command -v od >/dev/null 2>&1; then
        n=$(od -An -N4 -tu4 /dev/urandom 2>/dev/null | tr -d ' ')
        [ -n "$n" ] || n=$(date +%s)
    else
        n=$(date +%s)
    fi
    echo $(( (n % 496) + 5 ))
}

# Decide what URL `?page=` and body `pageNo` to use for a given URL pagination
# index. Mirrors the web app:
#   - if --pattern set: pageNo=1
#   - else:             pageNo=random(5..500), URL page iterates 1..N
_msisdn_body_page() {
    if [ -n "$PATTERN" ]; then
        echo 1
    else
        random_page
    fi
}

# ---------- list-numbers mode ----------

list_numbers_mode() {
    api_auth
    api_session
    url_page=1
    pages_left="$PAGES"
    while [ "$pages_left" -gt 0 ]; do
        body_page=$(_msisdn_body_page)
        body=$(api_find_msisdn "$url_page" "$body_page" "$PATTERN") || return 1
        count=$(printf '%s' "$body" | jq -r '.result.data.noMsisdn | length')
        total=$(printf '%s' "$body" | jq -r '.result.data.totalPageMsisdn // 0')
        log_verbose "url_page=$url_page count=$count total_pages=$total"
        printf '%s' "$body" | jq -r '
            .result.data.noMsisdn[]
            | "\(.msisdn)\t\(.encrypt)"
        '
        pages_left=$((pages_left - 1))
        url_page=$((url_page + 1))
        # Stop when we exceed totalPageMsisdn to avoid empty pages.
        if [ "$total" -gt 0 ] && [ "$url_page" -gt "$total" ]; then
            break
        fi
    done
}

# Pick the first available MSISDN; if --pick-msisdn was given, find that one
# in the listing and use its encrypt blob.
pick_msisdn() {
    api_auth
    api_session
    url_page=1
    body_page=$(_msisdn_body_page)
    body=$(api_find_msisdn "$url_page" "$body_page" "$PATTERN") || return 1
    if [ -n "$PICK_MSISDN" ]; then
        target="$PICK_MSISDN"
        # tolerate both 0817-... and raw digits
        target_clean=$(printf '%s' "$target" | tr -d ' -')
        line=$(printf '%s' "$body" \
            | jq -r --arg t "$target_clean" \
                '.result.data.noMsisdn[] | select(.msisdn == $t) | "\(.msisdn)\t\(.encrypt)"' \
            | head -n1)
        if [ -z "$line" ]; then
            die "pick-msisdn: $target not found on page $url_page (try --list-numbers --pattern ...)"
        fi
    else
        # Guard with `if length == 0 then empty` so an empty array yields ""
        # instead of jq's default "null\tnull" output (which would otherwise
        # slip past the `[ "$line" = "null" ]` check below).
        line=$(printf '%s' "$body" \
            | jq -r '
                if (.result.data.noMsisdn | length) == 0
                then empty
                else .result.data.noMsisdn[0]
                     | "\(.msisdn)\t\(.encrypt)"
                end')
    fi
    # Defense-in-depth: also reject "null" or "null\tnull" if jq behaviour
    # changes upstream.
    case "$line" in
        ""|null|null*null) line="" ;;
    esac
    if [ -z "$line" ]; then
        die "no MSISDN available (url_page=$url_page body_pageNo=$body_page)"
    fi
    SELECTED_MSISDN=$(printf '%s' "$line" | cut -f1)
    SELECTED_ENCRYPT=$(printf '%s' "$line" | cut -f2)
    log_info "selected MSISDN: $SELECTED_MSISDN"
}

# _prompt_choice VARNAME "Label"
# Ask the user to pick mode 1 (random) or 2 (manual).
# Pressing Enter accepts the default (1=random). The result is assigned to
# VARNAME with the literal string "random" or "manual". Returns rc=130 with
# a clear message on EOF instead of silently exiting under `set -eu`.
# _prompt_email - render a numbered menu of HYFE_EMAIL_N accounts loaded from
# the config (if any), plus a "ketik manual" entry. When the user picks an
# account that has a matching HYFE_IMAP_PASS_N, that password is also
# loaded into HYFE_IMAP_PASS so the IMAP polling step can run unattended.
_prompt_email() {
    # Discover how many email slots are configured.
    _ec=0
    _i=1
    while :; do
        eval "_v=\${HYFE_EMAIL_$_i:-}"
        [ -n "$_v" ] || break
        _ec=$_i
        _i=$((_i + 1))
    done
    if [ "$_ec" = 0 ]; then
        _prompt EMAIL "Email (yang akan menerima OTP)"
        return 0
    fi
    while :; do
        {
            printf 'Email:\n'
            _i=1
            while [ "$_i" -le "$_ec" ]; do
                eval "_label=\$HYFE_EMAIL_$_i"
                printf '  %d) %s\n' "$_i" "$_label"
                _i=$((_i + 1))
            done
            _manual_idx=$((_ec + 1))
            printf '  %d) ketik manual\n' "$_manual_idx"
            printf 'Pilih [1]: '
        } >&2
        if ! IFS= read -r _ans; then
            printf '\nhyfetrial: input dibatalkan (EOF)\n' >&2
            exit 130
        fi
        [ -z "$_ans" ] && _ans=1
        case "$_ans" in
            ''|*[!0-9]*)
                printf '  pilihan tidak valid\n' >&2
                continue
                ;;
        esac
        if [ "$_ans" -ge 1 ] && [ "$_ans" -le "$_ec" ]; then
            eval "EMAIL=\$HYFE_EMAIL_$_ans"
            # IMAP login = email address; pair the matching App Password
            # so the IMAP polling step can run unattended.
            HYFE_IMAP_USER="$EMAIL"
            export HYFE_IMAP_USER
            eval "_pass_val=\${HYFE_IMAP_PASS_$_ans:-}"
            if [ -n "$_pass_val" ]; then
                HYFE_IMAP_PASS="$_pass_val"
                export HYFE_IMAP_PASS
                log_verbose "imap: password loaded from HYFE_IMAP_PASS_$_ans"
            else
                # Slot exists but App Password is missing. Don't fail here
                # because OTP_MODE might be `manual`, but if the user later
                # switches to imap they'll get a confusing error. Warn now.
                log_warn "HYFE_IMAP_PASS_$_ans belum di-set untuk $EMAIL"
                log_warn "kalau pakai OTP IMAP, tambahkan via 'hyfetrial --email-config' (e/edit)"
            fi
            return 0
        elif [ "$_ans" = "$_manual_idx" ]; then
            _prompt EMAIL "Email (yang akan menerima OTP)"
            return 0
        else
            printf '  pilihan tidak valid (1..%d)\n' "$_manual_idx" >&2
        fi
    done
}

_prompt_choice() {
    _vname="$1"; _label="$2"
    while :; do
        {
            printf '%s\n' "$_label"
            printf '  1) random\n'
            printf '  2) ketik manual\n'
            printf 'Pilih [1]: '
        } >&2
        if ! IFS= read -r _ans; then
            printf '\nhyfetrial: input dibatalkan (EOF)\n' >&2
            exit 130
        fi
        [ -z "$_ans" ] && _ans=1
        case "$_ans" in
            1|random|r|R)  eval "$_vname=random";  return 0 ;;
            2|manual|m|M)  eval "$_vname=manual";  return 0 ;;
            *) printf '  (pilihan tidak valid; ketik 1 atau 2)\n' >&2 ;;
        esac
    done
}

_prompt() {
    # _prompt VARNAME "Question text" "default" [hidden=0|1] [allow_empty=0|1]
    #
    # Notes about robustness under `set -eu`:
    #   * `stty -echo` may fail on minimal busybox setups or when stdin/tty
    #     is in an unusual state; we wrap with `|| :` so a stty failure
    #     does not silently abort the whole CLI.
    #   * `read` returns non-zero on EOF (Ctrl+D, terminal disconnect, or
    #     stdin closed). Without explicit handling that non-zero status
    #     would trigger `set -e` and exit silently mid-prompt. Instead we
    #     detect the EOF, restore echo, and exit with a clear message and
    #     SIGINT-equivalent rc=130 so the user sees what happened.
    _vname="$1"; _q="$2"; _def="${3:-}"; _hidden="${4:-0}"; _allow_empty="${5:-0}"
    while :; do
        if [ -n "$_def" ]; then
            printf '%s [%s]: ' "$_q" "$_def" >&2
        else
            printf '%s: ' "$_q" >&2
        fi
        if [ "$_hidden" = 1 ]; then
            stty -echo 2>/dev/null || :
            if ! IFS= read -r _ans; then
                stty echo 2>/dev/null || :
                printf '\nhyfetrial: input dibatalkan (EOF)\n' >&2
                exit 130
            fi
            stty echo 2>/dev/null || :
            printf '\n' >&2
        else
            if ! IFS= read -r _ans; then
                printf '\nhyfetrial: input dibatalkan (EOF)\n' >&2
                exit 130
            fi
        fi
        [ -z "$_ans" ] && _ans="$_def"
        if [ -z "$_ans" ] && [ "$_allow_empty" != 1 ]; then
            printf '  (wajib diisi)\n' >&2
            continue
        fi
        eval "$_vname=\$_ans"
        return 0
    done
}

_prompt_captcha_mode() {
    while :; do
        {
            printf 'Mode captcha:\n'
            printf '  1. manual\n'
            printf '  2. nextcaptcha\n'
            printf '  3. 2captcha\n'
            printf '  4. anticaptcha\n'
            printf '  5. capsolver\n'
        } >&2
        _prompt _ans "Pilih mode captcha" "manual"
        case "$_ans" in
            1|manual)      HYFE_CAPTCHA_MODE=manual ;;
            2|nextcaptcha) HYFE_CAPTCHA_MODE=nextcaptcha ;;
            3|2captcha)    HYFE_CAPTCHA_MODE=2captcha ;;
            4|anticaptcha) HYFE_CAPTCHA_MODE=anticaptcha ;;
            5|capsolver)   HYFE_CAPTCHA_MODE=capsolver ;;
            *)
                printf '  pilihan tidak valid: %s\n' "$_ans" >&2
                continue
                ;;
        esac
        return 0
    done
}

_prompt_otp_mode() {
    while :; do
        {
            printf 'Mau pakai OTP via IMAP atau manual?\n'
            printf '  1. imap\n'
            printf '  2. manual\n'
        } >&2
        _prompt _ans "Pilih mode OTP" "manual"
        case "$_ans" in
            1|imap)    HYFE_OTP_MODE=imap ;;
            2|manual)  HYFE_OTP_MODE=manual ;;
            *)
                printf '  pilihan tidak valid: %s\n' "$_ans" >&2
                continue
                ;;
        esac
        return 0
    done
}

# Interactive wizard: prompts for any required input that wasn't supplied via
# CLI flag / config file. Triggered by --interactive or by absence of any
# required flag.
interactive_prompt() {
    if [ ! -t 0 ]; then
        die "interactive mode butuh terminal (stdin bukan TTY)"
    fi
    {
        printf '\n=== hyfetrial: mode interaktif ===\n'
        printf '(tekan Enter untuk pakai nilai default kalau ada)\n\n'
    } >&2
    # _name_mode / _wa_mode are populated by _prompt_choice via `eval`; declare
    # them up-front so shellcheck (SC2154) recognises them as locally assigned.
    _name_mode=""
    _wa_mode=""
    if [ -z "$NAME" ]; then
        _prompt_choice _name_mode "Nama lengkap"
        if [ "$_name_mode" = "random" ]; then
            NAME=$(random_indo_name)
            log_info "nama random: $NAME"
        else
            _prompt NAME "Nama lengkap"
        fi
    fi
    if [ -z "$WHATSAPP" ]; then
        _prompt_choice _wa_mode "Nomor WhatsApp"
        if [ "$_wa_mode" = "random" ]; then
            WHATSAPP=$(random_wa_local)
            log_warn "WA random: 0$WHATSAPP - nomor ini tidak akan menerima pesan/OTP WA"
        else
            _prompt WHATSAPP "Nomor WhatsApp (tanpa +62/0)"
        fi
    fi
    [ -z "$EMAIL" ]    && _prompt_email
    if [ -z "$EID" ]; then
        {
            printf '\nEID HARUS dari device yang akan dipakai untuk eSIM ini.\n'
            printf '  - Cek di iPhone:  Settings > General > About > EID\n'
            printf '  - Cek di Android: Settings > About phone > SIM status > EID\n'
            printf '  - Random/EID milik device lain = QR eSIM tidak bisa diaktifkan.\n\n'
        } >&2
        _prompt EID "EID eSIM (32 digit)"
    fi
    if [ -z "$PATTERN" ] && [ -z "$PICK_MSISDN" ]; then
        _prompt PATTERN "Pola digit nomor cantik (kosongkan untuk random)" "" 0 1
    fi
    if [ "$HYFE_CAPTCHA_MODE" = "manual" ] || [ -z "${HYFE_CAPTCHA_MODE:-}" ]; then
        _prompt_captcha_mode
        case "$HYFE_CAPTCHA_MODE" in
            2captcha|anticaptcha|capsolver|nextcaptcha)
                if [ -z "${HYFE_CAPTCHA_KEY:-}" ]; then
                    _prompt HYFE_CAPTCHA_KEY "API key untuk $HYFE_CAPTCHA_MODE" "" 1
                fi
                ;;
        esac
        export HYFE_CAPTCHA_MODE HYFE_CAPTCHA_KEY
    fi
    if [ "${HYFE_OTP_MODE:-manual}" = "manual" ]; then
        _prompt_otp_mode
        if [ "$HYFE_OTP_MODE" = "imap" ]; then
            : "${HYFE_IMAP_URL:=imaps://imap.gmail.com:993}"
            _prompt HYFE_IMAP_URL  "IMAP URL"  "$HYFE_IMAP_URL"
            _prompt HYFE_IMAP_USER "IMAP user" "${HYFE_IMAP_USER:-$EMAIL}"
            [ -z "${HYFE_IMAP_PASS:-}" ] && _prompt HYFE_IMAP_PASS "IMAP pass (App Password)" "" 1
        fi
        export HYFE_OTP_MODE HYFE_IMAP_URL HYFE_IMAP_USER HYFE_IMAP_PASS
    fi
    printf '\n' >&2
}

# Auto-trigger interactive when nothing was given (and not in list/dry-help mode).
auto_interactive() {
    [ "$LIST_ONLY" = 1 ] && return 1
    [ "$INTERACTIVE" = 1 ] && return 0
    if [ -z "$NAME" ] && [ -z "$WHATSAPP" ] && [ -z "$EMAIL" ] && [ -z "$EID" ] && [ -z "$PICK_MSISDN" ]; then
        return 0
    fi
    return 1
}

confirm() {
    [ "$ASSUME_YES" = 1 ] && return 0
    {
        printf '\n'
        printf '  Akan submit data berikut:\n'
        printf '    nama   : %s\n' "$NAME"
        printf '    wa     : 62%s\n' "$WHATSAPP"
        printf '    email  : %s\n' "$EMAIL"
        printf '    msisdn : %s\n' "$SELECTED_MSISDN"
        printf '    eid    : %s\n' "$EID"
        printf '\n'
        printf '  Lanjut? [y/N] '
    } >&2
    IFS= read -r ans
    case "$ans" in
        y|Y|yes|YES) return 0 ;;
        *) return 1 ;;
    esac
}

# ---------- main flow ----------

# precheck_config - sanity-check that the loaded config has all the
# pieces we need for the chosen modes. Emits warnings (not errors) so
# the user can see what's missing before the actual claim attempt makes
# them wait through OTP timeouts or captcha errors.
precheck_config() {
    if [ "${HYFE_CAPTCHA_MODE:-manual}" != "manual" ] \
       && [ -z "${HYFE_CAPTCHA_KEY:-}" ]; then
        log_warn "HYFE_CAPTCHA_MODE=$HYFE_CAPTCHA_MODE tapi HYFE_CAPTCHA_KEY kosong"
        log_warn "captcha pasti gagal - jalankan 'hyfetrial --captcha-config'"
    fi
    if [ "${HYFE_OTP_MODE:-manual}" = "imap" ]; then
        if [ -z "${HYFE_IMAP_URL:-}" ]; then
            log_warn "HYFE_OTP_MODE=imap tapi HYFE_IMAP_URL kosong"
            log_warn "jalankan 'hyfetrial --imap-config' untuk isi setting IMAP"
        fi
        if [ -z "${HYFE_IMAP_USER:-}" ] && [ -z "${HYFE_EMAIL_1:-}" ]; then
            log_warn "HYFE_OTP_MODE=imap tapi belum ada email akun (HYFE_EMAIL_N kosong)"
            log_warn "jalankan 'hyfetrial --email-config' untuk daftarkan email"
        fi
        if [ -n "${HYFE_IMAP_USER:-}" ] && [ -z "${HYFE_IMAP_PASS:-}" ]; then
            log_warn "HYFE_IMAP_USER=$HYFE_IMAP_USER tapi HYFE_IMAP_PASS kosong"
            log_warn "OTP IMAP butuh App Password Gmail untuk login"
        fi
    fi
}

claim_flow() {
    validate_inputs

    precheck_config

    pick_msisdn

    confirm || die "aborted"

    log_info "step 1/3: requesting tnc opt-in"
    access_token=$(api_tnc_token) || die "tncToken failed"
    [ -n "$access_token" ] || die "tncToken returned empty"
    optin_body=$(api_tnc_optin "$EMAIL" "$access_token") || die "optIn failed"
    consent_id=$(printf '%s' "$optin_body" | jq -r '.result.data.consentId // empty')
    [ -n "$consent_id" ] || die "optIn: consentId missing"
    # The "tokentnc" header on validateAndSubmit is the Keycloak access_token
    # we obtained from /tnc/tncToken (not a field in the optIn response).
    tnc_token="$access_token"
    log_verbose "consentId=$consent_id"

    otp_capture_baseline || die "imap baseline failed"

    log_info "step 2/3: sending OTP email to $EMAIL"
    api_send_otp "$EMAIL" "$NAME" >/dev/null || die "send-otp failed"

    otp_code=$(otp_get) || die "otp not provided"
    log_verbose "otp=$otp_code"

    log_info "step 3/3: solving captcha (mode=$HYFE_CAPTCHA_MODE)"
    recap=$(captcha_solve) || die "captcha failed"
    [ -n "$recap" ] || die "captcha returned empty"

    if [ "$DRY_RUN" = 1 ]; then
        log_info "dry-run: would call validateAndSubmit"
        printf 'msisdn=%s eid=%s otp=%s recap=%.20s...\n' \
            "$SELECTED_MSISDN" "$EID" "$otp_code" "$recap"
        return 0
    fi

    log_info "submitting validateAndSubmit"
    resp=$(api_validate_submit \
        "$recap" "$otp_code" "$consent_id" \
        "$SELECTED_ENCRYPT" "$EID" \
        "$NAME" "$WHATSAPP" "$EMAIL" \
        "$tnc_token") || die "validateAndSubmit failed"
    sc=$(printf '%s' "$resp" | jq -r '.statusCode // empty')
    if [ "$sc" = "200" ]; then
        log_info "SUCCESS: eSIM trial submitted for $SELECTED_MSISDN"
        printf '%s\n' "$resp" | jq .
        return 0
    fi
    rc=$(printf '%s' "$resp" | jq -r '.result.data.result.resultCode // empty')
    rm=$(printf '%s' "$resp" | jq -r '.result.data.result.resultDesc // .statusMessage // empty')
    log_error "submit failed: statusCode=$sc resultCode=$rc resultDesc=$rm"
    printf '%s\n' "$resp" | jq . >&2 2>/dev/null || printf '%s\n' "$resp" >&2
    return 1
}

# ---------- subcommand dispatch ----------
# Config-management subcommands short-circuit the normal claim flow so
# the user can manage their config file without going through the full
# eSIM submit pipeline. They run BEFORE require_cmd / cookie jar setup
# so a freshly installed box without curl/jq can still configure things.
if [ "$SHOW_CONFIG" = 1 ]; then
    _path="${CONFIG_FILE:-$(config_default_path)}"
    if [ ! -f "$_path" ]; then
        printf 'hyfetrial: config %s tidak ada. Buat dengan: hyfetrial --new-config\n' "$_path" >&2
        exit 2
    fi
    config_show "$_path"
    exit 0
fi

if [ -n "$WIZARD_MODE" ]; then
    if [ ! -t 0 ]; then
        die "wizard config butuh terminal (stdin bukan TTY)"
    fi
    _path="${CONFIG_FILE:-$(config_default_path)}"
    case "$WIZARD_MODE" in
        new)     wizard_new_config "$_path" ;;
        captcha) wizard_captcha_config "$_path" ;;
        imap)    wizard_imap_config "$_path" ;;
        email)   wizard_email_config "$_path" ;;
    esac
    exit 0
fi

# Claim flow needs network tooling. Verify deps + create cookie jar now,
# after the config wizards above had a chance to run without them.
require_cmd curl jq

HYFE_COOKIES="${HYFE_COOKIES:-${TMPDIR:-/tmp}/hyfetrial-cookies.$$}"
export HYFE_COOKIES
trap 'rm -f "$HYFE_COOKIES"' EXIT INT TERM
: > "$HYFE_COOKIES"

if [ "$LIST_ONLY" = 1 ]; then
    list_numbers_mode
else
    if auto_interactive; then
        interactive_prompt
    fi
    claim_flow
fi
