# /etc/hyfetrial/config - default config auto-loaded by `esim` (HYFE menu)
#
# Sejak versi 0.2.0 hyfetrial dilebur ke dalam CLI `esim`. Semua wizard
# config diakses via menu interaktif `esim` -> opsi 7 (Klaim eSIM Trial
# HYFE) -> submenu config. Path file ini tidak berubah supaya config lama
# tetap kompatibel.
#
# Cara isi cepat (tanpa edit file): jalankan `esim`, pilih menu 7, lalu:
#   submenu 5 - Setup config (wizard awal full)
#   submenu 6 - Edit captcha config (mode + API key)
#   submenu 7 - Edit IMAP config (URL/folder/subject/timeout)
#   submenu 8 - Edit email config (multi-akun + App Password)
#   submenu 9 - Lihat config aktif (password ter-mask)
#
# Setelah config terisi:
#   submenu 1 - Klaim sekarang (interaktif)
#   submenu 3 - Setup Klaim Cepat (preferences buat klaim semi-otomatis)
#   submenu 4 - Klaim Cepat (pakai preferences di atas)

# ---------- captcha ----------
# Pilih salah satu mode:
#   manual       - default; CLI minta token grecaptcha hasil paste manual
#   2captcha     - https://2captcha.com/        (min top-up $1, $1-2.99/1000)
#   anticaptcha  - https://anti-captcha.com/    (min top-up $5, ~$2/1000)
#   capsolver    - https://capsolver.com/       (min top-up $5, $1/1000)
#   nextcaptcha  - https://nextcaptcha.com/     (FREE TRIAL via Telegram bot
#                                                @nextcaptcha_bot, then $0.6/1000)
#HYFE_CAPTCHA_MODE=manual
#HYFE_CAPTCHA_TIMEOUT=180

# Per-provider API key. Each provider has its own slot, jadi pindah mode
# tidak menghapus key provider lain. Cukup isi slot yang Anda pakai;
# slot yang lain bisa kosong / di-comment-out.
#HYFE_CAPTCHA_KEY_NEXTCAPTCHA=next_xxxxxxxxxxxxxxxxxxxx
#HYFE_CAPTCHA_KEY_2CAPTCHA=
#HYFE_CAPTCHA_KEY_ANTICAPTCHA=
#HYFE_CAPTCHA_KEY_CAPSOLVER=

# ---------- otp ----------
# Pilih salah satu mode:
#   manual       - default; CLI minta OTP 6 karakter hasil ketik manual
#   imap         - polling IMAP untuk auto-baca OTP
#                  butuh curl -V Protocols berisi "imap imaps"
#                  OpenWrt: build curl/libcurl dengan CONFIG_LIBCURL_IMAP=y
#HYFE_OTP_MODE=manual

# Jika HYFE_OTP_MODE=imap, isi setting server di bawah:
#HYFE_IMAP_URL=imaps://imap.gmail.com:993
#HYFE_IMAP_FOLDER=INBOX
#HYFE_IMAP_SUBJECT=Kode OTP | eSIM Trial HYFE
#HYFE_IMAP_TIMEOUT=180

# ---------- email accounts (multi) ----------
# Daftarkan satu atau lebih akun Gmail di sini. Saat hyfetrial jalan
# interaktif, prompt email akan menampilkan daftar ini sebagai menu.
# Pilih akun N -> hyfetrial otomatis pakai HYFE_IMAP_PASS_N untuk IMAP.
#
# Tambahkan/hapus pasangan ini lewat: `hyfetrial --email-config`
#
#HYFE_EMAIL_1=saya@gmail.com
#HYFE_IMAP_PASS_1="aaaa bbbb cccc dddd"
#
#HYFE_EMAIL_2=akun.kedua@gmail.com
#HYFE_IMAP_PASS_2="eeee ffff gggg hhhh"
#
#HYFE_EMAIL_3=akun.ketiga@gmail.com
#HYFE_IMAP_PASS_3="iiii jjjj kkkk llll"

# Single-account fallback (kalau tidak pakai HYFE_EMAIL_N):
#HYFE_IMAP_USER=me@gmail.com
#HYFE_IMAP_PASS=app-password-anda

# ---------- EID accounts (multi) ----------
# Saved EIDs untuk device yang Anda pakai klaim. Saat `esim` menu HYFE
# jalan interaktif, prompt EID akan menampilkan daftar ini sebagai menu,
# plus:
#   N+1) edit 3 digit terakhir (untuk nomor seri yang berurutan)
#   N+2) edit 4 digit terakhir
#   N+3) ketik manual (akan ditawarkan auto-save)
# Tambahkan/hapus pasangan ini lewat: edit langsung file ini, atau jawab
# "Y" pada prompt save di mode interaktif.
#HYFE_EID_1=89049032007208882600178661005175
#HYFE_EID_2=89049032007208882600178661005200

# ---------- klaim cepat (HYFE_QUICK_*) ----------
# Preferences buat fitur "Klaim Cepat" (esim menu 7 -> submenu 4). Otomatis
# di-set lewat wizard "Setup Klaim Cepat" (submenu 3). Tidak perlu di-edit
# manual; di sini cuma supaya format-nya keliatan.
#
#HYFE_QUICK_EMAIL_SLOT=1                                 # slot dari HYFE_EMAIL_*
#HYFE_QUICK_EID=89049032007208882600178661005200         # full EID (bisa hasil edit-tail)
#HYFE_QUICK_CAPTCHA_MODE=2captcha                        # manual/2captcha/anticaptcha/capsolver/nextcaptcha
#HYFE_QUICK_OTP_MODE=imap                                # imap/manual
#HYFE_QUICK_PATTERN=                                     # kosong = random page
#HYFE_QUICK_AUTO_PICK=1                                  # 1=auto-pick MSISDN pertama, 0=tetap pilih dari list

# ---------- misc ----------
#HYFE_VERBOSE=0
#HYFE_DEBUG=0
#HYFE_UA=Mozilla/5.0 (Linux; OpenWrt) ...
